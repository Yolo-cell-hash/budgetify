<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- SMS Permissions for reading bank transaction messages -->
    <uses-permission android:name="android.permission.RECEIVE_SMS"/>
    <uses-permission android:name="android.permission.READ_SMS"/>

    <!-- Privacy hardening: strip permissions that plugins pull in transitively
         but the app never actually uses. `another_telephony` declares
         ACCESS_COARSE_LOCATION; `open_filex` declares the READ_MEDIA_* group.
         The app reads SMS and opens its own export files — it needs neither.
         Removing them keeps the shipping manifest minimal and the "no tracking,
         offline" guarantee literally true. -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" tools:node="remove"/>
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" tools:node="remove"/>
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" tools:node="remove"/>
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" tools:node="remove"/>
    
    <!-- Notification permission for Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- Physical rumble for the royal screen-smash reaction. The impact-style
         haptics (HapticFeedback.*Impact) ride the system touch-feedback
         setting, which many users keep off; HapticFeedback.vibrate() drives
         the vibrator service directly and needs this permission. Normal
         (install-time) permission — no runtime prompt, no privacy surface. -->
    <uses-permission android:name="android.permission.VIBRATE"/>

    <!-- Biometric app lock -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC"/>
    
    <!-- Exports and encrypted backups are written through the Android system
         file picker (Storage Access Framework), so the app needs no broad
         storage permission. MANAGE_EXTERNAL_STORAGE ("All files access") is
         pinned out so it can never reach the shipping app: Google Play heavily
         restricts it and the app has no use for it. -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" tools:node="remove"/>

    <application
        android:label="Budgetify"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Royal launcher-icon variants (opt-in "Match app icon to my royal").
             Each alias re-skins the launcher icon for one royal avatar; all
             target MainActivity and ship DISABLED. At runtime exactly one
             launcher component is enabled: MainActivity (the default gold icon)
             or one of these aliases — toggled from Kotlin via
             PackageManager.setComponentEnabledSetting (see MainActivity.kt,
             channel "budgetify/app_icon"). Switching briefly relaunches the app
             (an Android limitation of alternate icons). No new permission. -->
        <activity-alias
            android:name=".MainActivityBronze"
            android:enabled="false"
            android:exported="true"
            android:label="Budgetify"
            android:icon="@mipmap/ic_launcher_bronze"
            android:roundIcon="@mipmap/ic_launcher_bronze_round"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".MainActivitySilver"
            android:enabled="false"
            android:exported="true"
            android:label="Budgetify"
            android:icon="@mipmap/ic_launcher_silver"
            android:roundIcon="@mipmap/ic_launcher_silver_round"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".MainActivityEmerald"
            android:enabled="false"
            android:exported="true"
            android:label="Budgetify"
            android:icon="@mipmap/ic_launcher_emerald"
            android:roundIcon="@mipmap/ic_launcher_emerald_round"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".MainActivityGolden"
            android:enabled="false"
            android:exported="true"
            android:label="Budgetify"
            android:icon="@mipmap/ic_launcher_golden"
            android:roundIcon="@mipmap/ic_launcher_golden_round"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".MainActivityRuby"
            android:enabled="false"
            android:exported="true"
            android:label="Budgetify"
            android:icon="@mipmap/ic_launcher_ruby"
            android:roundIcon="@mipmap/ic_launcher_ruby_round"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
        <activity-alias
            android:name=".MainActivityAmethyst"
            android:enabled="false"
            android:exported="true"
            android:label="Budgetify"
            android:icon="@mipmap/ic_launcher_amethyst"
            android:roundIcon="@mipmap/ic_launcher_amethyst_round"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
            
        <!-- SMS BroadcastReceiver for background SMS detection -->
        <receiver android:name="com.shounakmulay.telephony.sms.IncomingSmsReceiver"
            android:permission="android.permission.BROADCAST_SMS"
            android:exported="true">
            <intent-filter>
                <action android:name="android.provider.Telephony.SMS_RECEIVED"/>
            </intent-filter>
        </receiver>

        <!-- Home-screen budget widget -->
        <receiver android:name=".BudgetWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE"/>
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/budget_widget_info"/>
        </receiver>
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
