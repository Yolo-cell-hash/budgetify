<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive launcher icon (Android 8+). The gold brand mark on the navy
     background layer, so the system masks it to a clean circle/squircle and the
     Android 12+ launch splash shows a navy circle + gold mark instead of the
     legacy square icon jammed into a white circle. Pre-26 devices fall back to
     the bitmap @mipmap/ic_launcher.png. -->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background" />
    <foreground android:drawable="@mipmap/ic_launcher_foreground" />
</adaptive-icon>
