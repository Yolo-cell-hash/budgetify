<!--
  Notification status-bar (small) icon — the Budgetify brand mark.

  Android draws the small icon as an alpha-only silhouette, so this is the
  launcher icon's wallet-and-sprout reduced to a white-on-transparent glyph:
  a solid wallet with the clasp cut out (button kept), and the two sprout
  leaves above. A vector is safe because the app's minSdk is 24 — the
  "bad notification" RemoteServiceException for vector small icons only
  affects API < 24. Keep the resource name stable: it is referenced from Dart
  by name and pinned in res/raw/keep.xml for the release resource shrinker.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- Wallet body with clasp hole + button, in one even-odd path. -->
    <path
        android:fillColor="#FFFFFFFF"
        android:fillType="evenOdd"
        android:pathData="M5.5,9.5 L18.5,9.5 C19.88,9.5 21,10.62 21,12 L21,18.5 C21,19.88 19.88,21 18.5,21 L5.5,21 C4.12,21 3,19.88 3,18.5 L3,12 C3,10.62 4.12,9.5 5.5,9.5 Z M15.6,13 L18.2,13 C19.42,13 20.4,13.98 20.4,15.2 C20.4,16.42 19.42,17.4 18.2,17.4 L15.6,17.4 C14.38,17.4 13.4,16.42 13.4,15.2 C13.4,13.98 14.38,13 15.6,13 Z M15.8,15.2 C15.8,14.59 16.29,14.1 16.9,14.1 C17.51,14.1 18,14.59 18,15.2 C18,15.81 17.51,16.3 16.9,16.3 C16.29,16.3 15.8,15.81 15.8,15.2 Z" />
    <!-- Sprout: two solid leaves above the wallet. -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M12.4,8.6 C12.6,5.6 14.6,3.4 18.4,3.2 C18.2,6.8 16,8.6 12.4,8.6 Z M11.6,8.6 C8.4,8.4 6.6,6.6 6.4,3.8 C9.8,4.0 11.4,5.9 11.6,8.6 Z" />
</vector>
